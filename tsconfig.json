{
    "compilerOptions": {
        "module": "nodenext",
        "target": "ES2023",
        "lib": [
            "ES2023"
        ],
        "types": [
            "node"
        ],
        "rootDir": "src",
        "outDir": "out",
        "sourceMap": true,
        "inlineSources": true,
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "resolveJsonModule": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}

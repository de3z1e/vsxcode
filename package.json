{
    "name": "swift-package-helper",
    "displayName": "Swift Package Helper",
    "description": "Xcode project integration for VS Code — IntelliSense, build tasks, and simulator debugging.",
    "version": "1.3.1",
    "publisher": "de3z1e",
    "icon": "images/icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/de3z1e/SwiftPackageHelper.git"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Other"
    ],
    "keywords": [
        "swift",
        "xcode",
        "package.swift",
        "ios-simulator",
        "sourcekit-lsp"
    ],
    "extensionDependencies": [
        "swiftlang.swift-vscode"
    ],
    "activationEvents": [
        "onDebug",
        "workspaceContains:**/*.xcodeproj"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "swiftPackageHelper.createFromXcodeproj",
                "title": "Swift: Generate Package.swift from Xcode Project"
            },
            {
                "command": "swiftPackageHelper.createFromXcodeprojWithOptions",
                "title": "Swift: Generate Package.swift from Xcode Project (with Options)"
            },
            {
                "command": "swiftPackageHelper.generateBuildTasks",
                "title": "Swift: Generate VS Code Build Tasks"
            }
        ],
        "keybindings": [
            {
                "key": "cmd+r",
                "command": "workbench.action.debug.start",
                "when": "swiftPackageHelper.buildTasksConfigured && !inDebugMode"
            },
            {
                "key": "cmd+r",
                "command": "runCommands",
                "args": {
                    "commands": [
                        "workbench.action.debug.stop",
                        {"command": "workbench.action.debug.start", "delay": 1000}
                    ]
                },
                "when": "swiftPackageHelper.buildTasksConfigured && inDebugMode"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./",
        "prepublish": "npm run compile",
        "package": "vsce package"
    },
    "files": [
        "out",
        "images/icon.png",
        "README.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.85.0",
        "@vscode/vsce": "^3.6.2",
        "typescript": "^5.4.0"
    }
}

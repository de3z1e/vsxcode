{
    "name": "vsxcode",
    "displayName": "VSXcode",
    "description": "Xcode project integration for VS Code — IntelliSense, build tasks, device/simulator debugging, and native swift-format code formatting.",
    "version": "3.4.11",
    "publisher": "de3z1e",
    "icon": "images/icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/de3z1e/vsxcode.git"
    },
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Formatters",
        "Linters"
    ],
    "keywords": [
        "swift",
        "xcode",
        "package.swift",
        "ios-simulator",
        "sourcekit-lsp",
        "swift-format",
        "formatter",
        "linter",
        "ios",
        "debugger"
    ],
    "extensionDependencies": [
        "swiftlang.swift-vscode"
    ],
    "activationEvents": [
        "onDebug",
        "workspaceContains:**/*.pbxproj"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "vsxcode",
                    "title": "VSXcode",
                    "icon": "images/sidebar.svg"
                }
            ]
        },
        "views": {
            "vsxcode": [
                {
                    "id": "vsxcode.noProject",
                    "name": "VSXcode",
                    "icon": "images/sidebar.svg",
                    "when": "workspaceFolderCount > 0 && !vsxcode.hasXcodeProject"
                },
                {
                    "id": "vsxcode.sidebar",
                    "name": "Xcode Build",
                    "icon": "images/sidebar.svg",
                    "when": "vsxcode.hasXcodeProject"
                },
                {
                    "id": "vsxcode.codeFormat",
                    "name": "Code Format",
                    "icon": "images/sidebar.svg",
                    "type": "webview",
                    "when": "vsxcode.hasXcodeProject"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "vsxcode.noProject",
                "contents": "Searching for Xcode project..."
            }
        ],
        "commands": [
            {
                "command": "vsxcode.createFromXcodeproj",
                "title": "Swift: Generate Package.swift from Xcode Project"
            },
            {
                "command": "vsxcode.createFromXcodeprojWithOptions",
                "title": "Swift: Generate Package.swift from Xcode Project (with Options)"
            },
            {
                "command": "vsxcode.generateBuildTasks",
                "title": "Swift: Configure Build Tasks"
            },
            {
                "command": "vsxcode.sidebar.changeProject",
                "title": "Change Project"
            },
            {
                "command": "vsxcode.sidebar.changeTarget",
                "title": "Change Target"
            },
            {
                "command": "vsxcode.sidebar.changeScheme",
                "title": "Change Scheme"
            },
            {
                "command": "vsxcode.sidebar.changeBundleId",
                "title": "Change Bundle Identifier"
            },
            {
                "command": "vsxcode.sidebar.selectSimulator",
                "title": "Select Device"
            },
            {
                "command": "vsxcode.sidebar.changeSwiftVersion",
                "title": "Change Swift Compiler Version"
            },
            {
                "command": "vsxcode.sidebar.changeStrictConcurrency",
                "title": "Change Strict Concurrency Checking"
            },
            {
                "command": "vsxcode.sidebar.build",
                "title": "Build",
                "icon": "$(tools)"
            },
            {
                "command": "vsxcode.sidebar.buildAndRun",
                "title": "Build & Run",
                "icon": "$(debug-alt)"
            },
            {
                "command": "vsxcode.sidebar.refresh",
                "title": "Refresh",
                "icon": "$(refresh)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "vsxcode.sidebar.build",
                    "when": "view == vsxcode.sidebar",
                    "group": "navigation@1"
                },
                {
                    "command": "vsxcode.sidebar.buildAndRun",
                    "when": "view == vsxcode.sidebar",
                    "group": "navigation@2"
                },
                {
                    "command": "vsxcode.sidebar.refresh",
                    "when": "view == vsxcode.sidebar",
                    "group": "navigation@3"
                }
            ]
        },
        "taskDefinitions": [
            {
                "type": "xcode-build",
                "required": [
                    "task"
                ],
                "properties": {
                    "task": {
                        "type": "string",
                        "enum": [
                            "build",
                            "build-install",
                            "run-and-debug",
                            "test"
                        ],
                        "description": "The Xcode build task to run"
                    }
                }
            }
        ],
        "keybindings": [
            {
                "key": "cmd+r",
                "command": "vsxcode.sidebar.buildAndRun",
                "when": "vsxcode.buildTasksConfigured"
            },
            {
                "key": "cmd+shift+b",
                "command": "vsxcode.sidebar.build",
                "when": "vsxcode.buildTasksConfigured"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./",
        "prepublish": "npm run compile",
        "package": "vsce package"
    },
    "files": [
        "out",
        "images/icon.png",
        "images/sidebar.svg",
        "images/swift-light.svg",
        "images/swift-dark.svg",
        "README.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.110.0",
        "@vscode/vsce": "^3.6.2",
        "typescript": "^5.4.0"
    }
}

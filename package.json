{
    "name": "swift-package-helper",
    "displayName": "Swift Package Helper",
    "description": "Generate a Package.swift from the active Xcode project.",
    "version": "0.0.5",
    "publisher": "de3z1e",
    "icon": "images/icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/de3z1e/SwiftPackageHelper.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "swift",
        "swiftpm",
        "package.swift",
        "xcode",
        "spm"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "swiftPackageHelper.createFromXcodeproj",
                "title": "Swift: Generate Package.swift from Xcode Project"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./",
        "prepublish": "npm run compile",
        "package": "vsce package"
    },
    "files": [
        "out",
        "images/icon.png",
        "README.md",
        "LICENSE"
    ],
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.80.0",
        "@vscode/vsce": "^3.6.2",
        "typescript": "^5.4.0"
    }
}
